set refresh-mode = auto
set refresh-interval = 5

color cursor        default color8  bold

color title-blur    color8  color11
color title-focus   color0  color11 bold

set main-view = line-number:no,interval=5 id:yes,color=no date:relative,local=no,format= author:full,maxwidth=13 commit-title:yes,graph=v2,refs=yes
