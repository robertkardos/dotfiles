set refresh-mode = auto
set refresh-interval = 5

color cursor        color15 color8  

color title-blur    color8  color11
color title-focus   color0  color11 

color author        color6  default bold

set main-view = line-number:no,interval=6 id:yes,color=yes date:relative,local=no,format= author:full,maxwidth=13 commit-title:yes,graph=v2,refs=yes

